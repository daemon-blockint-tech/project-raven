\PYGZsh{}     b\PYGZsq{}\PYGZbs{}x01\PYGZbs{}x11\PYGZbs{}x00\PYGZsq{}      \PYGZsh{} Component 1: ID=1, sampling=0x11, QT=0
\PYGZsh{}     b\PYGZsq{}\PYGZbs{}x02\PYGZbs{}x11\PYGZbs{}x00\PYGZsq{}      \PYGZsh{} Component 2: ID=2, sampling=0x11, QT=0
\PYGZsh{}     b\PYGZsq{}\PYGZbs{}x03\PYGZbs{}x11\PYGZbs{}x00\PYGZsq{}      \PYGZsh{} Component 3: ID=3, sampling=0x11, QT=0
\PYGZsh{} )
