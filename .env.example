# Project Raven Configuration
# Copy this file to .env and fill in real values. Never commit .env to version control.

# ── Environment ────────────────────────────────────────────────────────────────
# dev | staging | prod   — prod refuses to start with insecure defaults.
RAVEN_ENVIRONMENT=dev

# ── API ────────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=false

# ── Database ───────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost/raven
REDIS_URL=redis://localhost:6379/0
POSTGRES_PASSWORD=change-me

# ── Security & JWT ─────────────────────────────────────────────────────────────
# SECRET_KEY: required >=32 chars in prod. Generate with: openssl rand -hex 32
SECRET_KEY=change-me-to-a-random-32-char-or-longer-string
JWT_ALGORITHM=HS256
JWT_ACCESS_TTL_MINUTES=15
JWT_REFRESH_TTL_DAYS=7
JWT_ISSUER=raven
JWT_AUDIENCE=raven-api

# Bootstrap admin (created on first start if both set). Min 12 chars.
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_PASSWORD=

# ── CORS ───────────────────────────────────────────────────────────────────────
# Comma-separated allowlist. Wildcard '*' refused in prod.
CORS_ORIGINS=http://localhost:3000

# ── Scan jail (closes F2) ──────────────────────────────────────────────────────
# /hunt/code and /hunt/variant only walk paths under this root.
SCAN_ROOT=/var/lib/raven/repos

# ── AI provider allowlist (closes F1) ──────────────────────────────────────────
# Comma-separated extra base_urls accepted by POST /ai/provider.
# Built-in defaults are always allowed.
AI_ALLOWED_BASE_URLS=

# ── Rate limiting ──────────────────────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_AUTH_PER_MINUTE=5

# ── Observability ──────────────────────────────────────────────────────────────
# OpenTelemetry OTLP gRPC endpoint (empty = tracing disabled).
OTEL_EXPORTER_OTLP_ENDPOINT=

# ── Tinker (Thinking Machines Lab) ────────────────────────────────────────────
# Get a key at https://auth.thinkingmachines.ai/sign-up (beta access required).
TINKER_API_KEY=
TINKER_USE_MOCK=false
TINKER_DEFAULT_BASE_MODEL=meta-llama/Llama-3.1-70B-Instruct
TINKER_DEFAULT_RANK=64
TINKER_MAX_CONCURRENT_JOBS=2

# Continual learning loop — operator opt-in. Prod-mode refuses to start without
# TINKER_API_KEY when this is true (or set TINKER_USE_MOCK=true for dry-run).
CONTINUAL_LEARNING_ENABLED=false
CONTINUAL_LEARNING_MIN_EXAMPLES=100

# A/B promotion defaults
ABTEST_DEFAULT_TRAFFIC_PCT=0.05
ABTEST_MIN_SAMPLES=500
ABTEST_PROMOTE_THRESHOLD_PCT=0.95

# ── Shodan (internet intelligence) ────────────────────────────────────────────
# Get a free key at https://account.shodan.io
SHODAN_API_KEY=your-shodan-api-key-here
SHODAN_MAX_RESULTS=100

# ── ML Configuration ───────────────────────────────────────────────────────────
MODEL_PATH=./models
ANOMALY_THRESHOLD=0.95
ZERO_DAY_CONFIDENCE=0.85

# ── AI Provider (runtime-switchable) ──────────────────────────────────────────
# Switch without restarting: `raven provider set openrouter --key sk-or-...`
# Or via API:  POST /ai/provider  {"provider":"openrouter","api_key":"sk-or-..."}
# Supports provider:model shorthand in AI_MODEL, e.g. openrouter:nous-hermes-2-mixtral-8x7b
#
# Supported providers:
#   lmstudio   — local LM Studio server (no key)
#   openai     — OpenAI API
#   openrouter — 300+ models via single key (https://openrouter.ai)
#   anthropic  — Anthropic Claude native SDK (pip install anthropic)
#   ollama     — local Ollama server (no key)
#   opencode   — OpenCode AI
#   nous       — Nous Research Portal (Hermes models)
AI_PROVIDER=lmstudio
AI_MODEL=
AI_API_KEY=
AI_BASE_URL=
AI_TIMEOUT=120
AI_TEMPERATURE=0.2
AI_MAX_TOKENS=4096

# ── OpenRouter-specific (only used when AI_PROVIDER=openrouter)
OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_HTTP_REFERER=https://raven.local
OPENROUTER_TITLE=Project Raven

# ── LM Studio (local AI inference, legacy keys kept for backward compat) ───────
# Download: https://lmstudio.ai  |  Start server on port 1234 before running Raven.
# Three specialist models are orchestrated automatically via ModelOrchestrator:
#   FAST   → ibm/granite-4-micro          (~2.5 GB, always resident)
#   REASON → nvidia/nemotron-3-nano-4b    (~3.5 GB, always resident)
#   VISION → zai-org/glm-4.6v-flash       (~5 GB, loaded on-demand, swaps REASON)
LMSTUDIO_BASE_URL=http://localhost:1234
LMSTUDIO_MODEL=ibm/granite-4-micro
LMSTUDIO_TIMEOUT=120
LMSTUDIO_TEMPERATURE=0.2
LMSTUDIO_MAX_TOKENS=4096
# Only required when LM Studio server authentication is enabled (Settings → Server → Auth)
LMSTUDIO_API_KEY=

# ── Tool Configuration ─────────────────────────────────────────────────────────
SSH_TIMEOUT=30
NMAP_TIMEOUT=300
METASPLOIT_TIMEOUT=600

# Nuclei vulnerability scanner
# Install: https://github.com/projectdiscovery/nuclei  (MIT license)
# Templates auto-downloaded on first run; set path to use a custom/offline copy.
NUCLEI_BINARY=nuclei
NUCLEI_TEMPLATES=
NUCLEI_TIMEOUT=300

# Empire C2 post-exploitation framework
# Install: https://github.com/BC-SECURITY/Empire  (BSD-3-Clause)
# Run Empire server before enabling; leave URL empty to disable Empire integration.
EMPIRE_URL=http://localhost:1337
EMPIRE_SSL_VERIFY=true

# Ghidra binary analysis
# Install: https://github.com/NationalSecurityAgency/ghidra/releases  (Apache 2.0)
# Requires JDK 21: https://adoptium.net/temurin/releases
# Install pyghidra: pip install pyghidra  (or use Ghidra's bundled support/)
GHIDRA_INSTALL_DIR=/opt/ghidra
GHIDRA_PROJECT_DIR=~/.raven/ghidra_projects
GHIDRA_TIMEOUT=300

# ── New tool adapters ──────────────────────────────────────────────────────
# WHOIS lookup (WhoisClient)
WHOIS_TIMEOUT=15

# ARES-v3 deterministic Solana smart contract auditor
# Install: git clone https://github.com/daemon-blockint-tech/ARES-v3 && cargo install --path crates/ares-cli
ARES_BINARY=ares
ARES_TIMEOUT=120
ARES_POLICY_FILE=

# Solana eBPF-for-Ghidra — Ghidra processor extension
# Install: https://github.com/blastrock/Solana-eBPF-for-Ghidra/releases
# Set GHIDRA_INSTALL_DIR (or GHIDRA_HOME) — used by both GhidraAnalyzer and EBPFGhidraSetup
# GHIDRA_INSTALL_DIR=/opt/ghidra

# CyberChef self-hosted server
# Deploy: docker compose --profile tools up cyberchef
CYBERCHEF_URL=http://localhost:3000

# ── Monitoring ─────────────────────────────────────────────────────────────
ENABLE_METRICS=true
METRICS_PORT=9090

# ── Logging ────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=./logs/raven.log
